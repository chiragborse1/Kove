{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Kova",
  "version": "1.0.0",
  "identifier": "ai.kova.app",
  "build": {
    "frontendDist": "../dist/control-ui",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm ui:dev",
    "beforeBuildCommand": "pnpm ui:build"
  },
  "app": {
    "windows": [
      {
        "title": "Kova — Your AI Team",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/kova-gateway"],
    "resources": [
      "binaries/kova-gateway-x86_64-pc-windows-msvc.bat",
      "binaries/kova-gateway-x86_64-pc-windows-msvc.ps1"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
