#!/usr/bin/env sh
set -eu

STATE_DIR="${1:-}"
RUNTIME_ROOT="${2:-}"
SOURCE_ROOT="${3:-}"

if [ -z "$STATE_DIR" ]; then
  echo "missing Kova state directory argument" >&2
  exit 1
fi

NODE_BIN=""
if command -v node >/dev/null 2>&1; then
  NODE_BIN="$(command -v node)"
elif command -v nodejs >/dev/null 2>&1; then
  NODE_BIN="$(command -v nodejs)"
fi

if [ -z "$NODE_BIN" ]; then
  echo "Kova requires Node.js 22.12+ on PATH to launch the gateway sidecar." >&2
  exit 1
fi

ROOT_DIR="$RUNTIME_ROOT"
if [ -z "$ROOT_DIR" ] || [ ! -f "$ROOT_DIR/openclaw.mjs" ]; then
  ROOT_DIR="$SOURCE_ROOT"
fi

if [ -z "$ROOT_DIR" ] || [ ! -f "$ROOT_DIR/openclaw.mjs" ]; then
  echo "could not locate bundled OpenClaw runtime" >&2
  exit 1
fi

export KOVA_STATE_DIR="$STATE_DIR"
export OPENCLAW_STATE_DIR="${OPENCLAW_STATE_DIR:-$STATE_DIR}"
export OPENCLAW_CONFIG_PATH="${OPENCLAW_CONFIG_PATH:-$OPENCLAW_STATE_DIR/openclaw.json}"

mkdir -p "$OPENCLAW_STATE_DIR"
cd "$ROOT_DIR"

exec "$NODE_BIN" "$ROOT_DIR/openclaw.mjs" gateway run --bind loopback --port 18789 --force
